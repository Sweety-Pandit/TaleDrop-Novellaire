# Copy this file to .env in the project root before running
# `docker compose up`. Values here are consumed by docker-compose.yml.
# (This is separate from backend/.env.example, which is for running the
# backend directly with `uvicorn`, outside Docker.)

# --- Postgres ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=taledrop_novellaire

# --- Auth ---
JWT_SECRET_KEY=change_this_secret_key_in_production

# --- Email (verification / password reset) ---
# Leave the defaults if you don't need real emails to send in local dev —
# the backend logs a warning and continues instead of crashing.
MAIL_USERNAME=example@example.com
MAIL_PASSWORD=changeme
MAIL_FROM=example@example.com
MAIL_SERVER=smtp.gmail.com

# --- Razorpay ---
RAZORPAY_KEY_ID=rzp_test_changeme
RAZORPAY_KEY_SECRET=changeme

# --- AI (Ollama) ---
OLLAMA_MODEL=llama3.1
